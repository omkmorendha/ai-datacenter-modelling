# Optional API keys for v0. The model runs fully without any of these,
# falling back to cached data and YAML assumptions. Copy to `.env` and fill in
# the keys you have.

# FRED (Federal Reserve Bank of St. Louis) API key.
# Free: https://fredaccount.stlouisfed.org/apikeys
# Without it, the FRED client falls back to the public CSV (fredgraph) endpoint,
# which needs no key but is less robust.
FRED_API_KEY=

# U.S. Energy Information Administration (EIA) v2 API key.
# Free: https://www.eia.gov/opendata/register.php
EIA_API_KEY=

# SEC EDGAR requires a descriptive User-Agent with contact info (not a key).
# See https://www.sec.gov/os/webmaster-faq#developers
SEC_USER_AGENT="ai-datacenter-macro-model omkmorendha@gmail.com"

# Optional: override the on-disk HTTP cache directory (default: data/raw/cache).
# AI_DC_CACHE_DIR=

# Optional: cache TTL in hours for remote data pulls (default: 24).
# AI_DC_CACHE_TTL_HOURS=24

# Optional: set to 1 to force offline mode (use cache/assumptions only, no network).
AI_DC_OFFLINE=0
